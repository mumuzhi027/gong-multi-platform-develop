<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <!-- 仅在设备具备加密备份能力时保存离线 Room 数据库。 -->
        <include domain="database" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="." />
    </device-transfer>
</data-extraction-rules>
